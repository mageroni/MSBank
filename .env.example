# =============================================================================
# Microservice Bank — Example environment file
# Copy to .env and adjust as needed. .env is gitignored.
# =============================================================================

# --- Global ---
COMPOSE_PROJECT_NAME=msbank
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- Kafka (Redpanda locally, Event Hubs in Azure) ---
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# For Event Hubs:
#   KAFKA_BOOTSTRAP_SERVERS=<namespace>.servicebus.windows.net:9093
#   KAFKA_SECURITY_PROTOCOL=SASL_SSL
#   KAFKA_SASL_MECHANISM=PLAIN
#   KAFKA_SASL_USERNAME=$ConnectionString
#   KAFKA_SASL_PASSWORD=<event-hubs-connection-string>

# --- Postgres (one DB per service) ---
POSTGRES_USER=msbank
POSTGRES_PASSWORD=msbank_dev_only
AUTH_DB_URL=jdbc:postgresql://postgres-auth:5432/auth
ACCOUNTS_DB_URL=jdbc:postgresql://postgres-accounts:5432/accounts
TRANSACTIONS_DB_URL=postgres://msbank:msbank_dev_only@postgres-transactions:5432/transactions?sslmode=disable
NOTIFICATIONS_DB_URL=postgresql+asyncpg://msbank:msbank_dev_only@postgres-notifications:5432/notifications

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth / JWT ---
JWT_ISSUER=https://auth.msbank.local
JWT_AUDIENCE=msbank
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
# RS256 keypair (PEM) — generated on first boot if absent
JWT_PRIVATE_KEY_PATH=/etc/msbank/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/etc/msbank/keys/jwt_public.pem

# --- API Gateway ---
GATEWAY_PORT=8080
GATEWAY_RATE_LIMIT_PER_MIN=120
GATEWAY_CORS_ORIGINS=http://localhost:3000

# --- Internal service-to-service auth (header X-Internal-Token) ---
INTERNAL_TOKEN=dev-internal-token-change-me

# --- Service URLs (within docker network) ---
AUTH_SERVICE_URL=http://auth-service:8081
ACCOUNTS_SERVICE_URL=http://accounts-service:8082
TRANSACTIONS_SERVICE_URL=http://transactions-service:8083
NOTIFICATIONS_SERVICE_URL=http://notifications-service:8084

# --- Notifications ---
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@msbank.local

# --- Web portal ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
